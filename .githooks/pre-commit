#!/bin/sh

# ── Smoke tests (Chromium only, ~8s) ───────────────────────────────
echo "Running smoke tests..."
npx playwright test --project=chromium
if [ $? -ne 0 ]; then
  echo "Smoke tests failed — commit aborted."
  exit 1
fi

# ── Upload media if changed ────────────────────────────────────────
MEDIA_CHANGED=$(git diff --cached --name-only -- 'public/*.mp4' 'public/*.mp3' 'public/*.mov' 'public/*.webm')

if [ -n "$MEDIA_CHANGED" ]; then
  echo "Media files changed — uploading to Cloudflare R2..."
  echo "$MEDIA_CHANGED"
  npm run upload-media
fi
